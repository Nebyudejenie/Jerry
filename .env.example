# =====================================================================
# Terry AI Autonomous Infrastructure OS — environment template
# Copy to .env and fill in. NEVER commit .env to git.
# =====================================================================

# ── general ──────────────────────────────────────────────────────────
TZ=UTC
N8N_HOST=n8n.example.local
GRAFANA_HOST=grafana.example.local
ACME_EMAIL=ops@example.com

# ── n8n ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
N8N_ENCRYPTION_KEY=replace_me_with_32_bytes_base64
N8N_WORKER_REPLICAS=2
N8N_WORKER_CONCURRENCY=5

# ── postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=terry
POSTGRES_DB=terry
POSTGRES_PASSWORD=replace_me_strong_password

# ── redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=replace_me_strong_password

# ── qdrant ───────────────────────────────────────────────────────────
QDRANT_API_KEY=replace_me_random_token

# ── vault (dev mode for homelab; rotate for prod) ────────────────────
VAULT_ROOT_TOKEN=replace_me_vault_root_token

# ── ollama ───────────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
# space-separated list pulled on bootstrap
OLLAMA_MODELS="qwen2.5-coder:7b llama3.1:8b nomic-embed-text"
# terry-router VRAM tier (homelab|startup|enterprise) — see ollama/routing/routing.yaml
VRAM_TIER=homelab

# ── grafana ──────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace_me_grafana

# ── llm providers (optional — Ollama is default) ─────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_me_from_botfather
TELEGRAM_CHAT_ID=replace_me_your_chat_id
TELEGRAM_APPROVERS=123456789,987654321   # comma-separated allowed user_ids

# ── target inventory (filled per environment) ────────────────────────
PROXMOX_HOST=proxmox.example.local
PROXMOX_USER=root@pam
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=

UNIFI_HOST=unifi.example.local
UNIFI_API_KEY=
UNIFI_SITE_ID=default

NAS_HOST=nas.example.local
NAS_USER=root

# ── SSH cert authority (Vault) ───────────────────────────────────────
VAULT_SSH_ROLE=terry-ops
VAULT_SSH_CA_PUBLIC_KEY_PATH=/etc/ssh/trusted-user-ca-keys.pem
TERRY_SSH_USER=terry

# ── n8n workflow IDs (set by `make import-workflows`) ────────────────
# These get populated automatically; leave blank for first boot.
WF_SSH_EXEC=
WF_APPROVAL=
WF_COMMANDER=
