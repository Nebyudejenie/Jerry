{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit-compliance-output",
  "description": "Return shape of the audit_writer.append() call. Not produced by an LLM.",
  "type": "object",
  "required": ["audit_id"],
  "additionalProperties": false,
  "properties": {
    "audit_id":     { "type": "string", "format": "uuid" },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "row_hash":     { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
