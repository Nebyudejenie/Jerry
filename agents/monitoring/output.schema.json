{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "monitoring-agent-output",
  "type": "object",
  "required": ["target_id", "status", "transitioned", "next_action"],
  "additionalProperties": false,
  "properties": {
    "target_id":    { "type": "string" },
    "status":       { "enum": ["up", "down", "degraded"] },
    "latency_ms":   { "type": ["integer", "null"], "minimum": 0 },
    "evidence":     { "type": "string", "maxLength": 500 },
    "transitioned": { "type": "boolean" },
    "next_action":  { "enum": ["none", "escalate"] }
  }
}
